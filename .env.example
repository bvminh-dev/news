# ==========================================================================
# Bản tin hàng ngày — mẫu cấu hình (KHÔNG điền giá trị thật vào file này)
# Copy sang .env.local và điền. .env* bị .gitignore chặn (trừ file này).
# Quy tắc: thiếu API key của một công cụ thu thập => công cụ đó bị BỎ QUA.
# ==========================================================================

# --- Bắt buộc ---
MONGODB_URI=
MONGODB_DB=ban_tin

# Auth admin (seed 1 lần vào collection admin_users)
# Sinh hash: node -e "console.log(require('bcryptjs').hashSync('matkhau', 10))"
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Bảo vệ endpoint cron/worker (Vercel Cron gửi header Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Gửi email (Gmail SMTP + App Password). Bắt buộc để bước gửi hoạt động.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
ADMIN_ALERT_EMAIL=

# --- Công cụ thu thập (tùy chọn — thiếu credential => loại adapter đó) ---
# Claude: adapter SPAWN `claude` CLI headless (claude -p) để web-search + tóm tắt +
#   chấm relevance tin 24h. Cần cài CLI: npm i -g @anthropic-ai/claude-code
#   ⚠️ Cách này KHÔNG chạy trên Vercel serverless (không spawn được binary) — dùng cho
#      môi trường tự host / long-running (VPS, container, chạy local).
# Xác thực bằng 1 trong 2 (nếu có cả hai, ưu tiên ANTHROPIC_AUTH_TOKEN):
#   - ANTHROPIC_API_KEY   : Console API key (sk-ant-api...) → CLI dùng ANTHROPIC_API_KEY (+ --bare)
#   - ANTHROPIC_AUTH_TOKEN: OAuth token Claude Code (sk-ant-oat...) → CLI dùng CLAUDE_CODE_OAUTH_TOKEN
#     Token subscription (sk-ant-oat) CHỈ chạy qua CLI (gọi thẳng Messages API bị 429).
#     Lưu ý: OAuth token ngắn hạn/hết hạn, không tự refresh — cần cập nhật lại khi hết hạn.
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
CLAUDE_MODEL=claude-opus-4-8
# (tùy chọn) đường dẫn bin CLI nếu không nằm trong PATH; timeout mỗi lần chạy CLI (ms)
CLAUDE_CLI_BIN=claude
CLAUDE_CLI_TIMEOUT_MS=180000
FIRECRAWL_API_KEY=
APIFY_TOKEN=

# --- Hàng đợi fan-out (tùy chọn — thiếu token => fallback waitUntil tuần tự) ---
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Cấu hình nghiệp vụ (không hardcode) ---
APP_TZ=Asia/Ho_Chi_Minh
APP_LANG=vi
DEFAULT_TOP_N=10
DEDUP_WINDOW_DAYS=14
NEWS_RETENTION_DAYS=30
RANK_WEIGHT_RELEVANCE=0.6
RANK_WEIGHT_ENGAGEMENT=0.4

# Base URL công khai (dựng link unsubscribe trong email)
PUBLIC_BASE_URL=http://localhost:3000
